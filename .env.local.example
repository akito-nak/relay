# Copy this file to .env.local and fill in your values.
# .env.local is in .gitignore — never commit real keys.

# ── LLM Provider ─────────────────────────────────────────
# Options: groq | openai | ollama
LLM_PROVIDER=groq

# ── Groq (free at console.groq.com) ──────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ── OpenAI (optional, for switching later) ────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Ollama (optional, for fully local inference) ──────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# ── Jira (Phase 3) ────────────────────────────────────────
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_DEFAULT_PROJECT=PROJ

# ── GitHub (Phase 4) ─────────────────────────────────────
GITHUB_TOKEN=ghp_your-token-here
GITHUB_DEFAULT_OWNER=your-github-username

# ── Slack (Phase 5) ───────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_APP_TOKEN=xapp-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_MODE=socket